# Copy to `.env.local-sync`, then fill your remote credentials.
# This file is intentionally safe to commit.

# execution mode
DRY_RUN=1
SYNC_COMPONENTS=all
REMOTE_NAME=staging

# local Leona defaults
LOCAL_PG_CONTAINER=leona-postgres
LOCAL_PGHOST=127.0.0.1
LOCAL_PGPORT=5432
LOCAL_PGDATABASE=leona
LOCAL_PGUSER=leona
LOCAL_PGPASSWORD=leona

LOCAL_REDIS_CONTAINER=leona-redis
LOCAL_REDIS_HOST=127.0.0.1
LOCAL_REDIS_PORT=6379
LOCAL_REDIS_PASSWORD=

# remote postgres
REMOTE_PGHOST=
REMOTE_PGPORT=5432
REMOTE_PGDATABASE=
REMOTE_PGUSER=
REMOTE_PGPASSWORD=

# remote redis
REMOTE_REDIS_HOST=
REMOTE_REDIS_PORT=6379
REMOTE_REDIS_PASSWORD=
