# Copy to `.env.local-sync`, then fill your remote credentials.
# This file is intentionally safe to commit.

# execution mode
DRY_RUN=1
SYNC_COMPONENTS=all
REMOTE_NAME=staging

# local Leona defaults
LOCAL_PG_CONTAINER=leona-postgres
LOCAL_PGHOST=127.0.0.1
LOCAL_PGPORT=5432
LOCAL_PGDATABASE=leona
LOCAL_PGUSER=leona
LOCAL_PGPASSWORD=leona

LOCAL_REDIS_CONTAINER=leona-redis
LOCAL_REDIS_HOST=127.0.0.1
LOCAL_REDIS_PORT=6379
LOCAL_REDIS_PASSWORD=

# remote postgres
REMOTE_PGHOST=
REMOTE_PGPORT=5432
REMOTE_PGDATABASE=
REMOTE_PGUSER=
REMOTE_PGPASSWORD=

# remote redis
REMOTE_REDIS_HOST=
REMOTE_REDIS_PORT=6379
REMOTE_REDIS_PASSWORD=

# optional ssh tunnel settings
SSH_SYNC_HOST=
SSH_SYNC_USER=
SSH_SYNC_PORT=
LOCAL_TUNNEL_PG_PORT=15432
LOCAL_TUNNEL_REDIS_PORT=16379
REMOTE_TUNNEL_PG_HOST=127.0.0.1
REMOTE_TUNNEL_PG_PORT=5432
REMOTE_TUNNEL_REDIS_HOST=127.0.0.1
REMOTE_TUNNEL_REDIS_PORT=6379
